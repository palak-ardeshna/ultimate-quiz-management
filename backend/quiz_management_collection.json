{
	"info": {
		"_postman_id": "quiz-mgmt-api-collection",
		"name": "Quiz Management System API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser\",\n    \"email\": \"test@gmail.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"register"
							]
						}
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.environment.set(\"authToken\", jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@gmail.com\",\n    \"password\": \"admin123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"login"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Quiz",
			"item": [
				{
					"name": "Create Quiz (Admin)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"General Knowledge\",\n    \"totalScore\": 100,\n    \"level\": \"Easy\",\n    \"questions\": [\n        {\n            \"questionText\": \"ભારતનું પાટનગર કયું છે?\",\n            \"options\": [\"મુંબઈ\", \"દિલ્હી\", \"અમદાવાદ\", \"સુરત\"],\n            \"correctAnswer\": \"દિલ્હી\"\n        }\n    ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/quiz",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"quiz"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get All Quizzes",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/quiz",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"quiz"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Quiz Attempt",
			"item": [
				{
					"name": "Submit Quiz Attempt",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"quizId\": \"REPLACE_WITH_QUIZ_ID\",\n    \"timeTaken\": 15\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/user-quiz/submit",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"user-quiz",
								"submit"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Rewards",
			"item": [
				{
					"name": "Request Redeem (User)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"pointsRequested\": 50\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/reward/request",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"reward",
								"request"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Pending Requests (Admin)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/reward/pending",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"reward",
								"pending"
							]
						}
					},
					"response": []
				},
				{
					"name": "Approve Redeem (Admin)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{authToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"adminPercentage\": 10\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/reward/approve/REPLACE_WITH_REQUEST_ID",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"reward",
								"approve",
								"REPLACE_WITH_REQUEST_ID"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000/api",
			"type": "string"
		},
		{
			"key": "authToken",
			"value": "",
			"type": "string"
		}
	]
}
